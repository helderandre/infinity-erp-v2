### 4.2 Google → ERP (Pull)

Ler eventos do Google Calendar para mostrar no calendário do ERP como "ocupação externa".

**Duas estratégias:**

#### Estratégia A: Polling (mais simples, recomendado para início)

Cron job que corre a cada 15 minutos:

```typescript
// /api/cron/sync-google-calendars
async function syncAllUsers() {
  const users = await getUsersWithGoogleSync()

  for (const user of users) {
    try {
      const accessToken = await getValidAccessToken(user.id)
      const calendarId = user.calendar_id || 'primary'

      // Buscar eventos dos próximos 30 dias
      const timeMin = new Date().toISOString()
      const timeMax = new Date(Date.now() + 30 * 24 * 60 * 60 * 1000).toISOString()

      const res = await fetch(
        `https://www.googleapis.com/calendar/v3/calendars/${calendarId}/events` +
        `?timeMin=${timeMin}&timeMax=${timeMax}&singleEvents=true&orderBy=startTime`,
        { headers: { Authorization: `Bearer ${accessToken}` } }
      )

      const data = await res.json()
      const googleEvents = data.items || []

      for (const ge of googleEvents) {
        // Ignorar eventos criados pelo ERP
        if (ge.extendedProperties?.private?.erp_source === 'infinity_erp') continue

        // Upsert no calendário ERP como evento externo
        await upsertExternalEvent(user.id, {
          google_event_id: ge.id,
          title: ge.summary || 'Evento Google',
          description: ge.description,
          start_time: ge.start?.dateTime || ge.start?.date,
          end_time: ge.end?.dateTime || ge.end?.date,
          location: ge.location,
          is_external: true,
          google_sync_status: 'synced',
        })
      }

      // Actualizar last_sync_at
      await updateLastSync(user.id)
    } catch (err) {
      console.error(`Sync failed for user ${user.id}:`, err)
    }
  }
}
```

#### Estratégia B: Push Notifications (mais eficiente, fase futura)

Google pode enviar webhooks quando um calendário muda:

```typescript
// Registar webhook (válido até 7 dias, renova automaticamente)
async function registerGoogleWatch(userId: string) {
  const accessToken = await getValidAccessToken(userId)
  const channelId = crypto.randomUUID()

  const res = await fetch(
    `https://www.googleapis.com/calendar/v3/calendars/primary/events/watch`,
    {
      method: 'POST',
      headers: {
        Authorization: `Bearer ${accessToken}`,
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        id: channelId,
        type: 'web_hook',
        address: 'https://erp.infinitygroup.pt/api/webhooks/google-calendar',
        expiration: Date.now() + 7 * 24 * 60 * 60 * 1000, // 7 dias
      }),
    }
  )

  // Guardar channel_id e expiration para renovação
}

// Webhook endpoint
// POST /api/webhooks/google-calendar
// Google envia notificação → trigger sync para o user afectado
```

